#!/usr/bin/env python3

"""
gpsync -- rsync to multiple hosts at once

Usage: gpsync [--version] [-?v] [-r] [-a] [-p port] [-u user]
             [-h host] [-f hostfile] [-J host_substitution_character] [[user@]host1:]file1 [...] [[user@]hosts2:]file2

             --version    : print version information
             -?           : print this help screen
             -v	          : verbose mode
             -r           : recursively copy entire directories
             -a           : archive mode; equals -rlptgoD (no -H,-A,-X)
             -h host      : ssh host to connect to (multiple -h is okay)
             -f file      : a file listing all hosts to connect to
             -J character : character to be substitute as hostname [default='=']
"""

import getopt
import os
import subprocess
import sys
from typing import TYPE_CHECKING

if TYPE_CHECKING:
    from typing import ClassVar, NoReturn

from .gppylib.gpparseopts import OptParser
from .gppylib.parseutils import canonicalize_address
from .gppylib.util import ssh_utils

__all__ = [
    "GV",
    "Global",
    "main",
    "parseCommandLine",
    "print_version",
    "progname",
    "usage",
]

progname = os.path.split(sys.argv[0])[-1]

# TODO:
# - [ ] Move command line parsing logic into ArgParser
# - [ ] Set `Global` class as pydantic Model for automatic validation.


#
# all the command line options
#
class Global:
    __slots__ = ["filePath", "opt"]

    script_name: ClassVar[str] = os.path.split(__file__)[-1]
    USER: ClassVar[str | None] = os.environ.get("LOGNAME") or os.environ.get("USER")

    def __init__(self):
        self.opt = {}
        self.opt["-v"] = False
        self.opt["-h"] = []
        self.opt["-f"] = None
        self.opt["-J"] = "=:"
        self.opt["-r"] = False
        self.opt["-a"] = False
        self.filePath = []


GV = Global()


################
def usage(exitarg: int, *, err_msg: str | None = None) -> NoReturn:
    if err_msg is not None:
        print(err_msg, file=sys.stderr)
    parser = OptParser()
    try:
        parser.print_help()
    except Exception:
        print(__doc__)
    sys.exit(exitarg)


#############
def print_version() -> NoReturn:
    print(f"{GV.script_name} version $Revision$")
    sys.exit(0)


#############
def parseCommandLine():
    try:
        (options, args) = getopt.getopt(sys.argv[1:], "?vraJ:p:u:h:f:", ["version"])
    except Exception as e:
        usage(0, err_msg=f"Error: {e!s}")

    for switch, val in options:
        if switch == "-?":
            usage(0)
        elif switch == "-v":
            GV.opt[switch] = True
        elif switch == "-f":
            GV.opt[switch] = val
        elif switch == "-h":
            GV.opt[switch].append(val)
        elif switch == "-J":
            GV.opt[switch] = val + ":"
        elif switch in {"-r", "-a"}:
            GV.opt[switch] = True
        elif switch == "--version":
            print_version()

    hf = ((len(GV.opt["-h"]) and 1) or 0) + ((GV.opt["-f"] and 1) or 0)
    if hf != 1:
        usage(
            1,
            err_msg="Error: please specify at least one of -h or -f args, but not both",
        )

    if len(args) < 2:
        usage(1, err_msg="Error: please specify local and remote file paths")

    GV.filePath = args


#############
def main():
    parseCommandLine()
    hostlist = ssh_utils.HostList()
    for h in GV.opt["-h"]:
        hostlist.add(h)
    if GV.opt["-f"]:
        hostlist.parseFile(GV.opt["-f"])

    try:
        hostlist.checkSSH()
    except ssh_utils.SSHError as e:
        sys.exit("[ERROR] " + str(e))

    GV.opt["-h"] = hostlist.filterMultiHomedHosts()
    if len(GV.opt["-h"]) == 0:
        usage(1, err_msg="Error: missing hosts in -h and/or -f arguments")

    rsync = 'rsync -e "ssh -o BatchMode=yes -o StrictHostKeyChecking=no"'
    if GV.opt["-r"]:
        rsync += " -r"
    if GV.opt["-a"]:
        rsync += " -a"

    proc = []
    for _peer in GV.opt["-h"]:
        peer: str = canonicalize_address(_peer)  # MPP-13617
        cmd = rsync + " "
        for f in GV.filePath:
            cmd += f.replace(GV.opt["-J"], f"{peer}:") + " "
        if GV.opt["-v"]:
            print("[INFO]", cmd)
        proc.append(
            subprocess.Popen(
                cmd, shell=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE
            )
        )

    withError = False
    for p in proc:
        for line in p.stdout.readlines():
            print("[OUT {}] {}".format("".join(p.args), line))
        status = p.wait()
        if status:
            print(
                "[ERROR %s] exit %d, cmd - %s"
                % (p.stderr.read(), status, "".join(p.args))
            )
            withError = True

    if withError:
        sys.exit(1)
    if GV.opt["-v"]:
        print("[INFO] completed successfully")


if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        sys.exit("\nInterrupted...")
